# =========================
logs/
*.log
tmp/
temp/

# =========================
# Node (if doc-gen or tooling uses it)
# =========================
node_modules/
npm-debug.log*

# =========================
# Python (if helper scripts use it)
# =========================
__pycache__/
*.pyc
.venv/
venv/


# =========================
# OS / Editor
# =========================
.DS_Store
Thumbs.db
*.orig

# VS Code — keep shared settings, ignore personal state
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# =========================
# Copilot / AI (local dev preferences)
# =========================
.github/copilot-instructions.md

# =========================
# Environment / Secrets
# =========================
.env
.env.*
*.secret
*.key
*.pem
*.pfx

# DPAPI credential vault (user-specific encrypted secrets)
**/Vault/
**/.vault-*
*.cred

# =========================
# Release build output
# =========================
release/

# =========================
# PowerShell / Module
# =========================
# PSScriptAnalyzer output
*ScriptAnalyzer*

# Module test scratch
TestResults/

